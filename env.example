# ── Trakt ──────────────────────────────────────────────────────────────────────
TRAKT_SYNC_ENABLED=true
TRAKT_CLIENT_ID=your_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
# Where to store the OAuth token file (default: ~/.config/trakt-seerr-connector/trakt_tokens.json)
# TRAKT_TOKEN_PATH=/config/trakt_tokens.json

# ── Seerr ──────────────────────────────────────────────────────────────────────
SEERR_BASE_URL=https://seerr.your-home:5055
SEERR_API_KEY=your_seerr_api_key
# Optional: post requests as a specific user ID
# SEERR_API_USER_ID=2
# Set to false only for self-signed certificates
SEERR_VERIFY_SSL=true

# ── MyAnimeList (optional) ──────────────────────────────────────────────────────
MAL_SYNC_ENABLED=false
MAL_USERNAME=your_mal_username
# Comma-separated statuses: watching, plan_to_watch, completed, on_hold, dropped
MAL_LIST_STATUSES=watching,plan_to_watch
# TMDB API key is required for MAL sync (used to resolve anime → TMDB IDs)
TMDB_API_KEY=your_tmdb_api_key

# ── Behaviour ──────────────────────────────────────────────────────────────────
# "all" = request all seasons; "first" = request season 1 only
TV_SEASONS_MODE=all
HTTP_TIMEOUT_SECONDS=60
# Where to store the deduplication database
# STATE_DB_PATH=/config/state.sqlite3

# ── Docker only ────────────────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=3600
